@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tensor: <https://w3id.org/rdf-tensor/vocab#> .

tensor:DataTensor a rdfs:Datatype ;
  dc:date "2026-02-20"^^xsd:date ;
  rdfs:label "Data Tensor" ;
  rdfs:comment "The datatype for a tensor representing numeric or boolean data."@en ;
  dc:creator "Nikita Kozlov" .

tensor:Range a rdfs:Datatype ;
  dc:date "2026-02-20"^^xsd:date ;
  rdfs:label "Range" ;
  rdfs:comment "The datatype for a range of numeric values."@en ;
  dc:creator "Nikita Kozlov" .
